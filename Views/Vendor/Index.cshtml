@model IReadOnlyList<Vendor>
@{
    ViewData["Title"] = "Vendors";
}

<section class="entity-page">
    <h1>Vendors</h1>
    <p class="text-muted">External suppliers used by companies.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Country</th>
                <th>Company</th>
                <th>Support email</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Country</td>
                <td>@item.Company?.Name</td>
                <td>@item.SupportEmail</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

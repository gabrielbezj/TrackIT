<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackIT</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrackIT.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="app-nav navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-dot" aria-hidden="true"></span>
                    <span>TrackIT</span>
                </a>

                <button class="navbar-toggler app-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNavMenu" aria-controls="appNavMenu"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="appNavMenu">
                    <ul class="navbar-nav ms-auto app-nav-list">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Company" asp-action="Index">Companies</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Department" asp-action="Index">Departments</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Employee" asp-action="Index">Employees</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Asset" asp-action="Index">Assets</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="AssetAssignment" asp-action="Index">Assignments</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="MaintenanceRecord" asp-action="Index">Maintenance</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="SoftwareLicense" asp-action="Index">Licenses</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Vendor" asp-action="Index">Vendors</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell container-fluid">
        <main role="main" class="app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-fluid">
            <span>&copy; 2026 TrackIT Lab 2</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

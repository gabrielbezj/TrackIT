@model Asset
@{
    ViewData["Title"] = "Asset Details";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Assets</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.InventoryTag</li>
    </ol>
</nav>

<section class="entity-page">
    <h1>@Model.Name</h1>
    <dl class="row">
        <dt class="col-sm-3">Inventory tag</dt>
        <dd class="col-sm-9">@Model.InventoryTag</dd>

        <dt class="col-sm-3">Type</dt>
        <dd class="col-sm-9">@Model.Type</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.Department?.Name</dd>

        <dt class="col-sm-3">Vendor</dt>
        <dd class="col-sm-9">@Model.Vendor?.Name</dd>

        <dt class="col-sm-3">Purchase</dt>
        <dd class="col-sm-9">@Model.PurchaseDate.ToString("yyyy-MM-dd") / @Model.PurchasePrice.ToString("C")</dd>

        <dt class="col-sm-3">Warranty expires</dt>
        <dd class="col-sm-9">@Model.WarrantyExpiresOn.ToString("yyyy-MM-dd")</dd>
    </dl>

    <a class="btn btn-outline-primary" asp-action="Index">Back to list</a>
</section>

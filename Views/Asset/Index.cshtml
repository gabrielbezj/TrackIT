@model IReadOnlyList<Asset>
@{
    ViewData["Title"] = "Assets";
}

<section class="entity-page">
    <h1>Assets</h1>
    <p class="text-muted">Hardware and device inventory.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tag</th>
                <th>Name</th>
                <th>Type</th>
                <th>Status</th>
                <th>Department</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.InventoryTag</td>
                <td>@item.Name</td>
                <td>@item.Type</td>
                <td>@item.Status</td>
                <td>@item.Department?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

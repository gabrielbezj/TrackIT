@model IReadOnlyList<Company>
@{
    ViewData["Title"] = "Companies";
}

<section class="entity-page">
    <h1>Companies</h1>
    <p class="text-muted">Overview of all registered companies in the mock repository.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>City</th>
                <th>Contact</th>
                <th>Departments</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.HeadquartersCity</td>
                <td>@item.ContactEmail</td>
                <td>@item.Departments.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

@model IReadOnlyList<AssetAssignment>
@{
    ViewData["Title"] = "Asset Assignments";
}

<section class="entity-page">
    <h1>Asset Assignments</h1>
    <p class="text-muted">Who uses which asset and until when.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Employee</th>
                <th>Asset</th>
                <th>Assigned</th>
                <th>Due back</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Employee?.FirstName @item.Employee?.LastName</td>
                <td>@item.Asset?.InventoryTag</td>
                <td>@item.AssignedOn.ToString("yyyy-MM-dd")</td>
                <td>@(item.DueBackOn?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

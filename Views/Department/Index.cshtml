@model IReadOnlyList<Department>
@{
    ViewData["Title"] = "Departments";
}

<section class="entity-page">
    <h1>Departments</h1>
    <p class="text-muted">All departments across companies.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Company</th>
                <th>Manager</th>
                <th>Budget</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Company?.Name</td>
                <td>@item.ManagerName</td>
                <td>@item.Budget.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>

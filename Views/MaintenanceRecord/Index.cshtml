@model IReadOnlyList<MaintenanceRecord>
@{
    ViewData["Title"] = "Maintenance Records";
}

<section class="entity-page">
    <h1>Maintenance Records</h1>
    <p class="text-muted">Logged preventive and corrective maintenance.</p>

    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Asset</th>
                <th>Date</th>
                <th>Description</th>
                <th>Cost</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Asset?.InventoryTag</td>
                <td>@item.PerformedOn.ToString("yyyy-MM-dd")</td>
                <td>@item.Description</td>
                <td>@item.Cost.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
